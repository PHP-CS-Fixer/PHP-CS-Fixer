{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "properties": {
        "tool": {
            "type": "string"
        },
        "version": {
            "type": "string"
        },
        "about": {
            "type": "string"
        },
        "command": {
            "type": "string"
        },
        "result": {
            "type": "string",
            "enum": [
                "OK",
                "violations"
            ]
        },
        "files_processed": {
            "type": "number"
        },
        "files_with_violations": {
            "type": "number"
        },
        "violations": {
            "type": "array",
            "uniqueItems": true,
            "items": {
                "type": "object",
                "properties": {
                    "file": {
                        "type": "string"
                    },
                    "applied_fixers": {
                        "type": "array",
                        "uniqueItems": true,
                        "items": {
                            "type": "string"
                        }
                    },
                    "diff": {
                        "type": "string"
                    }
                },
                "required": [
                    "file"
                ]
            }
        },
        "duration_s": {
            "type": "number"
        },
        "memory_mb": {
            "type": "number"
        }
    },
    "required": [
        "tool",
        "version",
        "about",
        "command",
        "result",
        "files_processed",
        "files_with_violations",
        "violations",
        "duration_s",
        "memory_mb"
    ]
}
