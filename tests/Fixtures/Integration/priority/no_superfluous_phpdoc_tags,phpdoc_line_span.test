--TEST--
Integration of fixers: no_superfluous_phpdoc_tags,phpdoc_line_span.
--RULESET--
{"no_superfluous_phpdoc_tags": true, "phpdoc_line_span": {"method": "single"}}
--EXPECT--
<?php
class Foo
{
    /**  */
    function bar() : string
    {
        return 'bar';
    }

    /** @return array<string, int> */
    public function baz(string $bar) : array
    {
        return [];
    }
}

--INPUT--
<?php
class Foo
{
    /** @return string */
    function bar() : string
    {
        return 'bar';
    }

    /**
     * @param string $bar
     * @return array<string, int>
     */
    public function baz(string $bar) : array
    {
        return [];
    }
}
